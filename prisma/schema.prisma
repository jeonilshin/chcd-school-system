generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Document {
  id           String       @id
  enrollmentId String
  type         DocumentType
  fileName     String
  fileSize     Int
  fileUrl      String
  mimeType     String
  uploadedAt   DateTime     @default(now())
  Enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
}

model Enrollment {
  id                             String                        @id
  userId                         String?
  schoolYear                     String
  program                        String
  studentStatus                  StudentStatus
  status                         EnrollmentStatus              @default(PENDING)
  lastName                       String
  firstName                      String
  middleName                     String
  nameExtension                  String?
  nickname                       String
  sex                            Sex
  age                            Int
  birthday                       DateTime
  placeOfBirth                   String
  religion                       String
  presentAddress                 String
  contactNumber                  String
  citizenship                    Citizenship
  citizenshipSpecification       String?
  fatherFullName                 String
  fatherOccupation               String?
  fatherContactNumber            String
  fatherEmail                    String?
  fatherEducationalAttainment    EducationalAttainment
  motherFullName                 String
  motherOccupation               String?
  motherContactNumber            String
  motherEmail                    String
  motherEducationalAttainment    EducationalAttainment
  maritalStatus                  MaritalStatus[]
  siblingsInformation            String?
  totalLearnersInHousehold       Int
  lastSchoolPreschoolName        String
  lastSchoolPreschoolAddress     String?
  lastSchoolElementaryName       String
  lastSchoolElementaryAddress    String?
  specialSkills                  SpecialSkill[]
  specialNeedsDiagnosis          String?
  responsiblePersonName          String
  responsiblePersonContactNumber String
  responsiblePersonEmail         String
  relationshipToStudent          String?
  enrollmentAgreementAcceptance  EnrollmentAgreementAcceptance
  withdrawalPolicyAcceptance     WithdrawalPolicyAcceptance
  profilePictureUrl              String
  createdAt                      DateTime                      @default(now())
  updatedAt                      DateTime
  Document                       Document[]
  User                           User?                         @relation(fields: [userId], references: [id])
  Student                        Student?

  @@index([schoolYear])
  @@index([status])
  @@index([studentStatus])
  @@index([userId])
}

model User {
  id         String       @id
  email      String       @unique
  name       String
  password   String
  role       Role
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  Enrollment Enrollment[]
}

model Teacher {
  id          String   @id
  name        String
  email       String   @unique
  phone       String
  address     String
  subject     String
  class       String
  employeeId  String   @unique
  profileUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Class       Class[]  @relation("ClassTeacher")
  Assignments Assignment[]

  @@index([employeeId])
  @@index([subject])
}

model Student {
  id                String                 @id
  studentId         String                 @unique
  enrollmentId      String                 @unique
  classId           String?
  status            StudentEnrollmentStatus @default(ACTIVE)
  admissionDate     DateTime               @default(now())
  
  // Personal Information (from enrollment)
  firstName         String
  lastName          String
  middleName        String
  nameExtension     String?
  nickname          String
  sex               Sex
  age               Int
  birthday          DateTime
  placeOfBirth      String
  religion          String
  presentAddress    String
  contactNumber     String
  citizenship       Citizenship
  profilePictureUrl String
  
  // Parent Information
  fatherFullName    String
  fatherContactNumber String
  fatherEmail       String?
  motherFullName    String
  motherContactNumber String
  motherEmail       String
  
  // Academic
  program           String
  schoolYear        String
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  Enrollment        Enrollment    @relation(fields: [enrollmentId], references: [id])
  Class             Class?        @relation(fields: [classId], references: [id])
  Attendance        Attendance[]
  Grade             Grade[]
  Bill              Bill[]

  @@index([studentId])
  @@index([classId])
  @@index([status])
}

model Announcement {
  id          String              @id
  title       String
  content     String              @db.Text
  category    AnnouncementCategory
  priority    AnnouncementPriority @default(NORMAL)
  targetAudience String[]         // ["PARENT", "STUDENT", "ALL"]
  publishDate DateTime            @default(now())
  expiryDate  DateTime?
  createdBy   String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([publishDate])
  @@index([priority])
}

model Attendance {
  id          String            @id
  studentId   String
  date        DateTime
  status      AttendanceStatus
  timeIn      String?
  timeOut     String?
  remarks     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  Student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([studentId])
  @@index([date])
  @@index([status])
}

model Grade {
  id          String    @id
  studentId   String
  subject     String
  quarter     String    // "First Quarter", "Second Quarter", etc.
  grade       Float
  remarks     String?
  teacher     String?
  schoolYear  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  Student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subject, quarter, schoolYear])
  @@index([studentId])
  @@index([schoolYear])
}

model Bill {
  id              String        @id
  studentId       String
  invoiceNumber   String        @unique
  description     String
  amount          Float
  dueDate         DateTime
  status          BillStatus    @default(PENDING)
  paidDate        DateTime?
  paidAmount      Float?
  paymentMethod   String?
  receiptNumber   String?
  schoolYear      String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  Student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@index([dueDate])
}

model ClassSchedule {
  id          String    @id
  classId     String
  dayOfWeek   DayOfWeek
  subject     String
  startTime   String    // "08:00"
  endTime     String    // "09:00"
  teacher     String?
  room        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  Class       Class     @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, dayOfWeek, startTime])
  @@index([classId])
}

model Class {
  id              String          @id
  name            String
  program         String
  schoolYear      String
  section         String?
  capacity        Int             @default(30)
  teacherId       String?
  roomNumber      String?
  schedule        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  Teacher         Teacher?        @relation("ClassTeacher", fields: [teacherId], references: [id])
  Students        Student[]
  ClassSchedule   ClassSchedule[]
  Assignments     Assignment[]

  @@unique([name, schoolYear])
  @@index([program])
  @@index([schoolYear])
}

model SchoolSettings {
  id              String   @id @default("default")
  schoolName      String   @default("School")
  schoolLogoUrl   String?
  primaryColor    String   @default("#3B82F6")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum StudentEnrollmentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  WITHDRAWN
}

enum Citizenship {
  FILIPINO
  FOREIGNER
}

enum DocumentType {
  REPORT_CARD
  BIRTH_CERTIFICATE
  GOOD_MORAL
  MARRIAGE_CONTRACT
  MEDICAL_RECORDS
  SPECIAL_NEEDS_DIAGNOSIS
  PROOF_OF_PAYMENT
}

enum EducationalAttainment {
  ELEMENTARY_GRADUATE
  HIGH_SCHOOL_GRADUATE
  COLLEGE_GRADUATE
  ELEMENTARY_UNDERGRAD
  HIGH_SCHOOL_UNDERGRAD
  COLLEGE_UNDERGRAD
  OTHERS
}

enum EnrollmentAgreementAcceptance {
  YES_COMMIT
  OTHER
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MaritalStatus {
  MARRIED
  SEPARATED
  SINGLE_PARENT
  STEPMOTHER
  STEPFATHER
  OTHER
}

enum Role {
  PARENT
  ADMIN
  PRINCIPAL
  TEACHER
}

enum Sex {
  FEMALE
  MALE
}

enum SpecialSkill {
  COMPUTER
  COMPOSITION_WRITING
  SINGING
  DANCING
  POEM_WRITING
  COOKING
  ACTING
  PUBLIC_SPEAKING
  OTHER
}

enum StudentStatus {
  OLD_STUDENT
  NEW_STUDENT
}

enum WithdrawalPolicyAcceptance {
  YES_AGREED
  NO_DISAGREE
}

enum AnnouncementCategory {
  ACADEMIC
  EVENT
  HEALTH
  LIBRARY
  GENERAL
  EMERGENCY
}

enum AnnouncementPriority {
  HIGH
  NORMAL
  LOW
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum BillStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  senderId        String
  senderRole      Role
  content         String   @db.Text
  attachmentUrl   String?
  attachmentName  String?
  attachmentSize  Int?
  attachmentType  String?
  isRead          Boolean  @default(false)
  isEdited        Boolean  @default(false)
  isDeleted       Boolean  @default(false)
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  Conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model Conversation {
  id              String   @id @default(cuid())
  parentId        String
  recipientId     String
  recipientRole   Role
  subject         String?
  isGroup         Boolean  @default(false)
  groupName       String?
  participants    String[] @default([])
  lastMessageAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  Messages        Message[]
  
  @@unique([parentId, recipientId])
  @@index([parentId])
  @@index([recipientId])
  @@index([isGroup])
}

model PushSubscription {
  id              String   @id @default(cuid())
  userId          String
  endpoint        String   @unique
  p256dh          String
  auth            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
}

model Assignment {
  id              String   @id @default(cuid())
  classId         String
  teacherId       String
  title           String
  description     String   @db.Text
  dueDate         DateTime?
  attachmentUrl   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  Class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  Teacher         Teacher  @relation(fields: [teacherId], references: [id])
  
  @@index([classId])
  @@index([teacherId])
  @@index([dueDate])
}
